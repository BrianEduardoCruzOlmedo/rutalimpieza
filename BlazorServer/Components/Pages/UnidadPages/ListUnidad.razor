@page "/listUnidades"
@using BlazorServer.Models
@inject UnidadService UnidadService
@inject TipoUnidadService TipoUnidadService

<h3>Catálogo de Unidades</h3>

<TablaCrudGenerica TItem="Unidad"
                   Items="listaUnidades"
                   OnCreate="AbrirModalCrear"
                   OnEdit="AbrirModalEditar"
                   OnView="AbrirModalVer"
                   OnDelete="AbrirModalEliminar">
    
    <Cabecera>
        <th>Id</th>
        <th>Nombre</th>
        <th>Tipo de unidad</th>
    </Cabecera>
    
    <Filas Context="unidad">
        <td>@unidad.Id</td>
        <td>@unidad.Nombre</td>
        <td>@unidad.TipoUnidad!.Nombre</td>
    </Filas>
</TablaCrudGenerica>

    <Modal @ref="modal_Create" title="Registrar Nueva Unidad">
        <BodyTemplate>
            <EditForm Model="unidadSeleccionado">
                <div class="mb-3">
                    <label class="form-label">Nombre</label>
                    <InputText class="form-control" @bind-Value="unidadSeleccionado.Nombre" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Tipo de Unidad</label>
                    <InputSelect class="form-select" @bind-Value="unidadSeleccionado.ID_TipoUnidad">
                        <option value="0">-- Seleccione un tipo --</option>
                        @if (listaTipos != null)
                        {
                            @foreach (var t in listaTipos)
                            {
                                <option value="@t.ID">@t.Nombre</option>
                            }
                        }
                    </InputSelect>
                </div>
            </EditForm>
        </BodyTemplate>
        <FooterTemplate>
            <Button Color="ButtonColor.Secondary" @onclick="() => modal_Create.HideAsync()">Cancelar</Button>
            <Button Color="ButtonColor.Primary" @onclick="GuardarCrear">Guardar Unidad</Button>
        </FooterTemplate>
    </Modal>

    <Modal @ref="modal_Update" title="Editar Unidad" ModalType="ModalType.Warning">
        <BodyTemplate>
            <EditForm Model="unidadSeleccionado">
                <div class="mb-3">
                    <label class="form-label">Nombre</label>
                    <InputText class="form-control" @bind-Value="unidadSeleccionado.Nombre" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Tipo de Unidad</label>
                    <InputSelect class="form-select" @bind-Value="unidadSeleccionado.ID_TipoUnidad">
                        <option value="0">-- Seleccione un tipo --</option>
                        @if (listaTipos != null)
                        {
                            @foreach (var t in listaTipos)
                            {
                                <option value="@t.ID">@t.Nombre</option>
                            }
                        }
                    </InputSelect>
                </div>
            </EditForm>
        </BodyTemplate>
        <FooterTemplate>
            <Button Color="ButtonColor.Secondary" @onclick="() => modal_Update.HideAsync()">Cancelar</Button>
            <Button Color="ButtonColor.Primary" @onclick="GuardarEditar">Actualizar Unidad</Button>
        </FooterTemplate>
    </Modal>

    <Modal @ref="modal_Read" title="Detalles de Unidad" ModalType="ModalType.Info">
        <BodyTemplate>
            <ul class="list-group list-group-flush">
                <li class="list-group-item"><strong>Id:</strong> @unidadSeleccionado?.Id</li>
                <li class="list-group-item"><strong>Nombre:</strong> @unidadSeleccionado?.Nombre</li>
                <li class="list-group-item"><strong>Tipo:</strong> @unidadSeleccionado?.TipoUnidad?.Nombre</li>
            </ul>
        </BodyTemplate>
        <FooterTemplate>
            <Button Color="ButtonColor.Primary" @onclick="() => modal_Read.HideAsync()">Cerrar</Button>
        </FooterTemplate>
    </Modal>

    <Modal @ref="modal_Delete" title="Eliminar Unidad" ModalType="ModalType.Danger">
        <BodyTemplate>
            <p class="text-danger">¿Estás seguro que deseas eliminar la unidad <strong>@unidadSeleccionado?.Nombre</strong>?</p>
        </BodyTemplate>
        <FooterTemplate>
            <Button Color="ButtonColor.Secondary" @onclick="() => modal_Delete.HideAsync()">Cancelar</Button>
            <Button Color="ButtonColor.Danger" @onclick="ConfirmarEliminar">Sí, Eliminar</Button>
        </FooterTemplate>
    </Modal>



@code {
    private Modal modal_Create = new();
    private Modal modal_Read = new();
    private Modal modal_Update = new();
    private Modal modal_Delete = new();
    
    private List<Unidad> listaUnidades = new();
    private Unidad? unidadSeleccionado;
    private List<Tipo_Unidad> listaTipos = new();

    protected override async Task OnInitializedAsync()
    {
        listaUnidades = await UnidadService.GetUnidades() ?? new();
        listaTipos = await TipoUnidadService.GetTipos() ?? new();
    }

    public async Task AbrirModalCrear()
    {
        unidadSeleccionado = new Unidad();
        // cargar tipos para el select
        StateHasChanged();
        await Task.Delay(30);
        await modal_Create.ShowAsync();
    }

    public async Task AbrirModalEditar(Unidad unidad)
    {
        unidadSeleccionado = unidad;
        await modal_Update.ShowAsync();
    }

    public async Task AbrirModalVer(Unidad unidad)
    {
        unidadSeleccionado = unidad;
        await modal_Read.ShowAsync();
    }

    public async Task AbrirModalEliminar(Unidad unidad)
    {
        unidadSeleccionado = unidad;
        await modal_Delete.ShowAsync();
    }

    public async Task GuardarCrear()
    {
        if (unidadSeleccionado == null) return;
        await UnidadService.Create(unidadSeleccionado);
        await modal_Create.HideAsync();
        listaUnidades = await UnidadService.GetUnidades() ?? new();
        StateHasChanged();
    }

    public async Task GuardarEditar()
    {
        if (unidadSeleccionado == null) return;
        await UnidadService.Update(unidadSeleccionado.Id, unidadSeleccionado);
        await modal_Update.HideAsync();
        listaUnidades = await UnidadService.GetUnidades() ?? new();
        StateHasChanged();
    }

    public async Task ConfirmarEliminar()
    {
        if (unidadSeleccionado == null) return;
        await UnidadService.Delete(unidadSeleccionado.Id);
        await modal_Delete.HideAsync();
        listaUnidades = await UnidadService.GetUnidades() ?? new();
        StateHasChanged();
    }
}