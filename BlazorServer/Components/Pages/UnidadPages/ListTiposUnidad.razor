@page "/listTiposUnidad"
@using BlazorServer.Models
@inject TipoUnidadService TipoUnidadService

<h3>Catálogo de Tipos de Unidad</h3>

<TablaCrudGenerica TItem="Tipo_Unidad"
                   Items="listaTipos"
                   OnCreate="AbrirModalCrear"
                   OnEdit="AbrirModalEditar"
                   OnView="AbrirModalVer"
                   OnDelete="AbrirModalEliminar">
    
    <Cabecera>
        <th>Id</th>
        <th>Nombre</th>
        <th>Lts Tanque</th>
    </Cabecera>
    
    <Filas Context="tipo">
        <td>@tipo.ID</td>
        <td>@tipo.Nombre</td>
        <td>@tipo.LtrsDieselTanque</td>
    </Filas>
</TablaCrudGenerica>

    <Modal @ref="modal_Create" title="Registrar Nuevo Tipo de Unidad">
        <BodyTemplate>
            <EditForm Model="tipoSeleccionado">
                <div class="mb-3">
                    <label class="form-label">Nombre</label>
                    <InputText class="form-control" @bind-Value="tipoSeleccionado.Nombre" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Ltrs Tanque</label>
                    <InputNumber class="form-control" @bind-Value="tipoSeleccionado.LtrsDieselTanque" />
                </div>
            </EditForm>
        </BodyTemplate>
        <FooterTemplate>
            <Button Color="ButtonColor.Secondary" @onclick="() => modal_Create.HideAsync()">Cancelar</Button>
            <Button Color="ButtonColor.Primary" @onclick="GuardarCrear">Guardar Tipo</Button>
        </FooterTemplate>
    </Modal>

    <Modal @ref="modal_Update" title="Editar Tipo de Unidad" ModalType="ModalType.Warning">
        <BodyTemplate>
            <EditForm Model="tipoSeleccionado">
                <div class="mb-3">
                    <label class="form-label">Nombre</label>
                    <InputText class="form-control" @bind-Value="tipoSeleccionado.Nombre" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Ltrs Tanque</label>
                    <InputNumber class="form-control" @bind-Value="tipoSeleccionado.LtrsDieselTanque" />
                </div>
            </EditForm>
        </BodyTemplate>
        <FooterTemplate>
            <Button Color="ButtonColor.Secondary" @onclick="() => modal_Update.HideAsync()">Cancelar</Button>
            <Button Color="ButtonColor.Primary" @onclick="GuardarEditar">Actualizar Tipo</Button>
        </FooterTemplate>
    </Modal>

    <Modal @ref="modal_Read" title="Detalles del Tipo" ModalType="ModalType.Info">
        <BodyTemplate>
            <ul class="list-group list-group-flush">
                <li class="list-group-item"><strong>Id:</strong> @tipoSeleccionado?.ID</li>
                <li class="list-group-item"><strong>Nombre:</strong> @tipoSeleccionado?.Nombre</li>
                <li class="list-group-item"><strong>Ltrs Tanque:</strong> @tipoSeleccionado?.LtrsDieselTanque</li>
            </ul>
        </BodyTemplate>
        <FooterTemplate>
            <Button Color="ButtonColor.Primary" @onclick="() => modal_Read.HideAsync()">Cerrar</Button>
        </FooterTemplate>
    </Modal>

    <Modal @ref="modal_Delete" title="Eliminar Tipo" ModalType="ModalType.Danger">
        <BodyTemplate>
            <p class="text-danger">¿Estás seguro que deseas eliminar el tipo <strong>@tipoSeleccionado?.Nombre</strong>?</p>
        </BodyTemplate>
        <FooterTemplate>
            <Button Color="ButtonColor.Secondary" @onclick="() => modal_Delete.HideAsync()">Cancelar</Button>
            <Button Color="ButtonColor.Danger" @onclick="ConfirmarEliminar">Sí, Eliminar</Button>
        </FooterTemplate>
    </Modal>

@code {
    private Modal modal_Create = new();
    private Modal modal_Read = new();
    private Modal modal_Update = new();
    private Modal modal_Delete = new();
    
    private List<Tipo_Unidad> listaTipos = new();
    private Tipo_Unidad? tipoSeleccionado;

    protected override async Task OnInitializedAsync()
    {
        // Se cambió a GetTipos() para coincidir con tu servicio
        listaTipos = await TipoUnidadService.GetTipos() ?? new();
    }

    public async Task AbrirModalCrear()
    {
        tipoSeleccionado = new Tipo_Unidad();
        await modal_Create.ShowAsync();
    }

    public async Task AbrirModalEditar(Tipo_Unidad tipo)
    {
        tipoSeleccionado = tipo;
        await modal_Update.ShowAsync();
    }

    public async Task AbrirModalVer(Tipo_Unidad tipo)
    {
        tipoSeleccionado = tipo;
        await modal_Read.ShowAsync();
    }

    public async Task AbrirModalEliminar(Tipo_Unidad tipo)
    {
        tipoSeleccionado = tipo;
        await modal_Delete.ShowAsync();
    }

    public async Task GuardarCrear()
    {
        if (tipoSeleccionado == null) return;
        await TipoUnidadService.Create(tipoSeleccionado);
        await modal_Create.HideAsync();
        listaTipos = await TipoUnidadService.GetTipos() ?? new();
        StateHasChanged();
    }

    public async Task GuardarEditar()
    {
        if (tipoSeleccionado == null) return;
        await TipoUnidadService.Update(tipoSeleccionado.ID, tipoSeleccionado);
        await modal_Update.HideAsync();
        listaTipos = await TipoUnidadService.GetTipos() ?? new();
        StateHasChanged();
    }

    public async Task ConfirmarEliminar()
    {
        if (tipoSeleccionado == null) return;
        await TipoUnidadService.Delete(tipoSeleccionado.ID);
        await modal_Delete.HideAsync();
        listaTipos = await TipoUnidadService.GetTipos() ?? new();
        StateHasChanged();
    }
}