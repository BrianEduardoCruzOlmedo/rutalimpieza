@page "/listTiposUnidad"
@using BlazorServer.Models
@inject TipoUnidadService TipoUnidadService

<h3>Catálogo de Tipos de Unidad</h3>

<TablaCrudGenerica TItem="Tipo_Unidad"
                   Items="listaTipos"
                   OnCreate="AbrirModalCrear"
                   OnEdit="AbrirModalEditar"
                   OnView="AbrirModalVer"
                   OnDelete="AbrirModalEliminar">
    
    <Cabecera>
        <th>Id</th>
        <th>Nombre</th>
        <th>Lts Tanque</th>
    </Cabecera>
    
    <Filas Context="tipo">
        <td>@tipo.ID</td>
        <td>@tipo.Nombre</td>
        <td>@tipo.LtrsDieselTanque</td>
    </Filas>
</TablaCrudGenerica>

@code {
    private Modal modal_Create = new();
    private Modal modal_Read = new();
    private Modal modal_Update = new();
    private Modal modal_Delete = new();
    
    private List<Tipo_Unidad> listaTipos = new();
    private Tipo_Unidad? tipoSeleccionado;

    protected override async Task OnInitializedAsync()
    {
        // Se cambió a GetTipos() para coincidir con tu servicio
        listaTipos = await TipoUnidadService.GetTipos() ?? new();
    }

    public async Task AbrirModalCrear()
    {
        tipoSeleccionado = new Tipo_Unidad();
        await modal_Create.ShowAsync();
    }

    public async Task AbrirModalEditar(Tipo_Unidad tipo)
    {
        tipoSeleccionado = tipo;
        await modal_Update.ShowAsync();
    }

    public async Task AbrirModalVer(Tipo_Unidad tipo)
    {
        tipoSeleccionado = tipo;
        await modal_Read.ShowAsync();
    }

    public async Task AbrirModalEliminar(Tipo_Unidad tipo)
    {
        tipoSeleccionado = tipo;
        await modal_Delete.ShowAsync();
    }
}