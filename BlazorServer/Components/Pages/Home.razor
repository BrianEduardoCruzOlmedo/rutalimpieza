@page "/"
@page "/dashboard"
@implements IDisposable
@using BlazorServer.Models
@inject DetalleDiarioService detalleService
@inject EmpleadoService empleadoService
@inject UnidadService unidadService

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>Panel de Control General</h3>
    <button class="btn btn-primary" @onclick="CargarDatos">
        <i class="oi oi-reload"></i> Actualizar Datos
    </button>
</div>

@if (cargando)
{
    <div class="text-center mt-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Cargando indicadores...</span>
        </div>
        <p class="mt-2"><em>Calculando métricas...</em></p>
    </div>
}
else
{
    <div class="row">
        <div class="col-md-4 mb-3">
            <div class="card text-white bg-primary shadow">
                <div class="card-body">
                    <h5 class="card-title">Total de Rutas (Folios)</h5>
                    <h1 class="card-text fw-bold">@totalFolios</h1>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card text-white bg-success shadow">
                <div class="card-body">
                    <h5 class="card-title">Choferes Activos</h5>
                    <h1 class="card-text fw-bold">@totalChoferes</h1>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card text-white bg-warning shadow">
                <div class="card-body">
                    <h5 class="card-title">Unidades de Transporte</h5>
                    <h1 class="card-text fw-bold">@totalUnidades</h1>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-12">
            <div class="card shadow">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">Últimos 5 Folios Registrados</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover mb-0 dashboard-table">
                        <thead class="table-light">
                            <tr>
                                <th>Folio</th>
                                <th>Fecha Orden</th>
                                <th>Fecha de Captura</th>
                                <th>Fecha Termino estimado</th>
                                <th>Fecha Termino real</th>

                                <th>ID_unidad</th>
                                <th>Unidad</th>

                                <th>ID ruta</th>
                                <th>Ruta</th>
                                <th>Empleados</th>

                                <th>Km Recorridos</th>
                                <th>Diesel Inicio</th>
                                <th>Diesel Recargado</th>
                               
                                <th>Diesel Final</th>
                                <th>Capacidad Diesel</th>
                                <th>Autonomia</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ultimosFolios.Any())
                            {
                                @foreach (var folio in ultimosFolios)
                                {
                                    <tr>
                                        <td><strong>#@folio.ID</strong></td>
                                        <td>@folio.Fecha_orden.ToString("dd/MM/yyyy")</td>
                                        <td>@folio.Fecha_Inicio.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>@folio.Fecha_TerminoEstimado.ToString("dd/MM/yyyy")</td>
                                        <td>@folio.Fecha_TerminoReal.ToString("dd/MM/yyyy HH:mm")</td>

                                        <td>@folio.ID_Unidad</td>
                                        <td>@folio.Unidad?.Nombre</td>

                                        <td>@folio.ID_Ruta</td>
                                        <td>@folio.Ruta?.Nombre</td>
                                        <td>@(folio.Empleados != null ? string.Join(", ", folio.Empleados.Select(e => e.Nombre)) : string.Empty)</td>

                                        <td>@folio.km_Recorridos</td>
                                        <td>@folio.Diesel_inicio</td>
                                        <td>@folio.Diesel_Recargado</td>

                                        <td>@folio.Diesel_Final</td>
                                        <td>@folio.CapacidadDiesel</td>
                                        <td>@folio.Autonomia</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-3">No hay folios registrados todavía.</td>
                                </tr>
                            }
                        </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool cargando = true;
    
    // Variables para las tarjetas
    private int totalFolios = 0;
    private int totalChoferes = 0;
    private int totalUnidades = 0;
    
    // Lista para la tabla resumen
    private List<DetalleDiario> ultimosFolios = new();

    protected override void OnInitialized()
    {
        // Suscribirse a cambios en folios para refrescar el dashboard automáticamente
        detalleService.OnChange += OnFoliosChanged;
    }

    private async void OnFoliosChanged()
    {
        await InvokeAsync(async () => await CargarDatos());
    }

    public void Dispose()
    {
        detalleService.OnChange -= OnFoliosChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        cargando = true;

        // Mandamos a llamar a tus servicios en paralelo para que cargue más rápido
        var foliosTask = detalleService.GetFolios();
        var choferesTask = empleadoService.GetChoferes();
        var unidadesTask = unidadService.GetUnidades();

        await Task.WhenAll(foliosTask, choferesTask, unidadesTask);

        var folios = foliosTask.Result;
        var choferes = choferesTask.Result;
        var unidades = unidadesTask.Result;

        // Calculamos los totales si las listas no vienen nulas
        if (folios != null)
        {
            totalFolios = folios.Count;
            // Tomamos solo los últimos 5 ordenados por el ID más grande
            ultimosFolios = folios.OrderByDescending(f => f.ID).Take(5).ToList();
        }
        
        if (choferes != null) totalChoferes = choferes.Count;
        if (unidades != null) totalUnidades = unidades.Count;

        cargando = false;
    }
}